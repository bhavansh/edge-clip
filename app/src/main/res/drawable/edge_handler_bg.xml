<?xml version="1.0" encoding="utf-8"?>
<!--
    Edge handle: Samsung One UI style
    - Dark translucent pill, rounded on the left side only (attaches to right edge)
    - Works on both light and dark wallpapers
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- #66000000 = 40% black — visible on any wallpaper, One UI standard -->
    <solid android:color="#66000000" />

    <corners
        android:topLeftRadius="20dp"
        android:bottomLeftRadius="20dp"
        android:topRightRadius="20dp"
        android:bottomRightRadius="20dp" />

</shape>